{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/node_modules/**)",
      "Read(**/__pycache__/**)",
      "Read(**/*.pyc)",
      "Read(**/.venv/**)",
      "Read(**/venv/**)",
      "Read(**/.pytest_cache/**)",
      "Read(**/.ruff_cache/**)",
      "Read(**/dist/**)",
      "Read(**/.angular/**)",
      "Read(**/build/**)",
      "Read(**/*.egg-info/**)",
      "Read(.git/**)",
      "Read(**/chroma_data/**)",
      "Read(**/*.db)",
      "Read(**/*.sqlite)",
      "Read(**/*.log)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-start.sh",
            "once": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-bash.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'RagKit compaction: KEEP: FastAPI/Angular file diffs, failing pytest/ng test errors, ChromaDB/Ollama config changes, RAG pipeline decisions, architecture constraints from constitution.md. DROP: passing test output, uvicorn startup logs, pip install output, redundant .env.example reads, resolved discussions, superseded approaches.'"
          }
        ]
      }
    ]
  }
}
