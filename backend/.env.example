# PALO RAG — Environment Configuration Example
# Copy to .env and fill in real values

# === AI Provider ===
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5:7b
EMBED_MODEL=mxbai-embed-large

# === Database ===
DB_URL=postgresql://palo:palo@localhost:5444/palo_rag

# === ChromaDB ===
CHROMA_PATH=./chroma_data

# === CORS ===
CORS_ALLOW_ORIGINS=http://localhost:4200

# === Auth / JWT ===
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=8
DEMO_USERNAME=admin
# Generate: python -c "import bcrypt; print(bcrypt.hashpw(b'changeme', bcrypt.gensalt()).decode())"
DEMO_PASSWORD_HASH=$2b$12$CHANGE_THIS_TO_A_REAL_BCRYPT_HASH
